# ─── Upstream SOCKS5 proxy (the proxy you rented) ────────────────────────────
UPSTREAM_HOST=
UPSTREAM_PORT=
UPSTREAM_USER=
UPSTREAM_PASS=

# ─── Local listener ───────────────────────────────────────────────────────────
LISTEN_HOST=0.0.0.0
LISTEN_PORT=1080

# ─── Tuning ───────────────────────────────────────────────────────────────────
# Connection timeout to upstream in milliseconds (default 30000)
CONN_TIMEOUT=30000
